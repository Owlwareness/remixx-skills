{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://remixx.dev/schemas/session-capture.v1.schema.json",
  "title": "session-capture.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "project", "period", "promise", "sources"],
  "properties": {
    "schemaVersion": { "const": "session-capture.v1" },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["projectId", "slug", "name"],
      "properties": {
        "projectId": { "type": "string", "format": "uuid" },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "maxLength": 80
        },
        "name": { "type": "string", "minLength": 1, "maxLength": 120 }
      }
    },
    "period": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startedAt", "endedAt"],
      "properties": {
        "startedAt": { "type": "string", "format": "date-time" },
        "endedAt": { "type": "string", "format": "date-time" }
      }
    },
    "promise": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "sourceRefs"],
      "properties": {
        "statement": { "type": "string", "minLength": 5, "maxLength": 1000 },
        "sourceRefs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "items": { "type": "string", "minLength": 1, "maxLength": 100 }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "kind", "label", "content", "proposedVisibility"],
        "properties": {
          "ref": { "type": "string", "minLength": 1, "maxLength": 100 },
          "kind": {
            "enum": [
              "agent_session",
              "repository",
              "artifact",
              "tool_result",
              "founder_statement",
              "external"
            ]
          },
          "label": { "type": "string", "minLength": 1, "maxLength": 200 },
          "content": { "type": "string", "maxLength": 1000000 },
          "proposedVisibility": { "enum": ["public", "private"] }
        }
      }
    }
  }
}
