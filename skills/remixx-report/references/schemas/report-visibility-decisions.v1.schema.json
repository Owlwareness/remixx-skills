{
  "$ref": "#/definitions/report-visibility-decisions.v1",
  "definitions": {
    "report-visibility-decisions.v1": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "report-visibility-decisions.v1"
        },
        "reportId": {
          "type": "string",
          "format": "uuid"
        },
        "reviewedBy": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "reviewedAt": {
          "type": "string",
          "format": "date-time"
        },
        "itemDecisions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "itemId": {
                "type": "string",
                "format": "uuid"
              },
              "truth": {
                "type": "string",
                "enum": ["confirmed", "rejected"]
              },
              "visibility": {
                "type": "string",
                "enum": ["public", "private", "omit"]
              }
            },
            "required": ["itemId", "truth", "visibility"],
            "additionalProperties": false
          },
          "minItems": 1,
          "maxItems": 300
        },
        "sourceDecisions": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "sourceId": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "visibility": {
                    "type": "string",
                    "const": "public"
                  },
                  "publicLabel": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 200
                  },
                  "publicLocator": {
                    "anyOf": [
                      {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 1000
                      },
                      {
                        "type": "null"
                      }
                    ]
                  }
                },
                "required": [
                  "sourceId",
                  "visibility",
                  "publicLabel",
                  "publicLocator"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "sourceId": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "visibility": {
                    "type": "string",
                    "enum": ["private", "omit"]
                  }
                },
                "required": ["sourceId", "visibility"],
                "additionalProperties": false
              }
            ]
          },
          "minItems": 1,
          "maxItems": 100
        }
      },
      "required": [
        "schemaVersion",
        "reportId",
        "reviewedBy",
        "reviewedAt",
        "itemDecisions",
        "sourceDecisions"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
