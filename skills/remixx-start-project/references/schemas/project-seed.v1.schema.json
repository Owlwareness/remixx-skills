{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://remixx.dev/schemas/project-seed.v1.schema.json",
  "title": "project-seed.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "projectId",
    "seedId",
    "project",
    "originStatements",
    "assumptions",
    "constraints",
    "experimentLadder",
    "repositoryUrl",
    "approval",
    "createdAt",
    "contentHash"
  ],
  "properties": {
    "schemaVersion": { "const": "project-seed.v1" },
    "projectId": { "type": "string", "format": "uuid" },
    "seedId": { "type": "string", "format": "uuid" },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "slug",
        "possibleFuture",
        "purpose",
        "whyNow",
        "currentState"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 100 },
        "slug": {
          "type": "string",
          "minLength": 2,
          "maxLength": 62,
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "possibleFuture": {
          "type": "string",
          "minLength": 10,
          "maxLength": 1000
        },
        "purpose": { "type": "string", "minLength": 10, "maxLength": 1500 },
        "whyNow": { "type": "string", "minLength": 10, "maxLength": 1500 },
        "currentState": {
          "type": "string",
          "minLength": 5,
          "maxLength": 1500
        }
      }
    },
    "originStatements": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["statementId", "provenanceKind", "text", "sourceLabel"],
        "properties": {
          "statementId": { "type": "string", "format": "uuid" },
          "provenanceKind": {
            "enum": [
              "founder_statement",
              "founder_recollection",
              "observed_source"
            ]
          },
          "text": { "type": "string", "minLength": 5, "maxLength": 1500 },
          "sourceLabel": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "maxItems": 30,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["assumptionId", "statement", "evidenceNeeded"],
        "properties": {
          "assumptionId": { "type": "string", "format": "uuid" },
          "statement": { "type": "string", "minLength": 5, "maxLength": 1000 },
          "evidenceNeeded": {
            "type": "string",
            "minLength": 5,
            "maxLength": 1000
          }
        }
      }
    },
    "constraints": {
      "type": "array",
      "maxItems": 30,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["constraintId", "statement"],
        "properties": {
          "constraintId": { "type": "string", "format": "uuid" },
          "statement": { "type": "string", "minLength": 5, "maxLength": 1000 }
        }
      }
    },
    "experimentLadder": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "experimentId",
          "order",
          "hypothesis",
          "action",
          "successSignal",
          "pivotIf"
        ],
        "properties": {
          "experimentId": { "type": "string", "format": "uuid" },
          "order": { "type": "integer", "minimum": 1, "maximum": 100 },
          "hypothesis": {
            "type": "string",
            "minLength": 5,
            "maxLength": 1000
          },
          "action": { "type": "string", "minLength": 5, "maxLength": 1500 },
          "successSignal": {
            "type": "string",
            "minLength": 5,
            "maxLength": 1000
          },
          "pivotIf": {
            "type": ["string", "null"],
            "minLength": 5,
            "maxLength": 1000
          }
        }
      }
    },
    "repositoryUrl": {
      "anyOf": [
        { "type": "string", "format": "uri", "maxLength": 1000 },
        { "type": "null" }
      ]
    },
    "approval": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "approvedBy", "approvedAt"],
          "properties": {
            "status": { "const": "draft" },
            "approvedBy": { "type": "null" },
            "approvedAt": { "type": "null" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "approvedBy", "approvedAt"],
          "properties": {
            "status": { "const": "approved" },
            "approvedBy": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            },
            "approvedAt": { "type": "string", "format": "date-time" }
          }
        }
      ]
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "contentHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
