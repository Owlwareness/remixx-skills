{
  "name": "@remixx/skills",
  "version": "0.1.0",
  "description": "Open, vendor-neutral skills and artifact tooling for living Remixx Projects",
  "type": "module",
  "private": true,
  "bin": {
    "remixx-artifact": "./bin/remixx-artifact.mjs"
  },
  "scripts": {
    "check": "npm run format:check && npm test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1"
  },
  "devDependencies": {
    "prettier": "3.5.3"
  }
}
